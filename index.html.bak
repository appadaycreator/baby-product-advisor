</div>
</div>

<footer style="text-align:center;padding:20px;color:white;font-size:12px;opacity:0.75;margin-top:8px;">
        <p><a target="_blank" rel="noopener noreferrer" href="https://appadaycreator.github.io/" style="color:white;">AppADayCreator</a>
        | <a href="privacy-policy.html" style="color:white;">プライバシーポリシー</a>
        | <a href="terms.html" style="color:white;">利用規約</a>
        | <a href="contact.html" style="color:white;">お問い合わせ</a></p>
        <p style="margin-top:4px;font-size:11px;opacity:0.6;">最終更新: 2026年5月 | 本サービスはアフィリエイト広告を掲載しています（A8.net/Amazon）</p>
        <p style="margin-top:6px;">© 2026 AppADayCreator. All services are free. | <a href="/tb-corp/?utm_source=appadaycreator&utm_medium=footer&utm_campaign=b2b_cta" onclick="gtag('event','b2b_cta_click',{source_page:location.pathname,cta_position:'footer',tool_category:'portal',destination:'tech-and-brace'})" style="color:white;opacity:0.75;font-size:11px;">Web制作・DX相談 → Tech&amp;Brace</a></p>
    </footer>

    <script>
    const QUESTIONS = [
      { text:'Q1. 赤ちゃんの月齢・状況は？', opts:['出産前（妊娠中）・準備中','0〜3ヶ月（新生児期）','4〜8ヶ月（寝返り〜離乳食開始）','9ヶ月〜1歳（つかまり立ち〜歩き始め）'] },
      { text:'Q2. 住まいの状況は？', opts:['1〜2LDKのマンション・アパート','3LDK以上の広い家','実家・親と同居','今後引越し予定あり'] },
      { text:'Q3. 授乳の予定は？', opts:['母乳育児を予定','混合（母乳+ミルク）の予定','ミルク育児の予定','まだ決めていない'] },
      { text:'Q4. 重視することは？', opts:['安全性・信頼できるブランド','コスパ・無駄なく揃えたい','利便性・時短・楽に育児したい','エコ・サステナブル'] },
      { text:'Q5. ベビー用品の予算は？（出産準備全体）', opts:['10万円以下に抑えたい','10〜20万円','20〜40万円でしっかり揃えたい','レンタル活用で初期投資を下げたい'] }
    ];
    const RESULTS = [
      { title:'👶 出産準備必需品リスト — 産前に揃えるべき5選', desc:'産前に揃えるべき最重要アイテムは①ベビーベッド（or バウンサー）②ベビー服（50〜60cm 5〜6枚）③オムツ・おしりふき④哺乳瓶（混合・ミルクなら必須）⑤チャイルドシートの5点です。ベビーカーは生後1ヶ月以降でOK。レンタルを活用すればベビーベッド・ハイローチェアなど使用期間が短い大型品を節約できます。西松屋・アカチャンホンポのセール・中古も賢く活用しましょう。' },
      { title:'🍼 新生児期の必需品 — 0〜3ヶ月に本当に必要なもの', desc:'新生児期に特に必要なのは①おくるみ（スワドルアップが大人気）②授乳クッション③ベビーモニター④白色雑音機（ホワイトノイズ）⑤沐浴グッズ（ベビーバス・ベビーソープ）です。エルゴやベビービョルンの抱っこ紐は首が据わる3ヶ月以降から活躍します。ベビーカーは外出が増える2〜3ヶ月ごろに購入しても遅くありません。' },
      { title:'🌟 離乳食・外出期の必需品 — 4〜8ヶ月向け', desc:'離乳食開始（6ヶ月ごろ）に向けて①ハイチェア（BEABAやカトージが人気）②離乳食セット（スプーン・こし器・製氷皿）③バウンサーまたはハイローチェア④ヒップシート型抱っこ紐（コニーなど軽量タイプ）が重要です。ベビーカーはA型（リクライニング）からB型（折り畳み軽量）への移行時期。外出が増える時期なので防水ベビーバッグも揃えましょう。' },
      { title:'🚶 つかまり立ち〜歩き始め期 — 安全グッズと靴が最優先', desc:'この時期に最優先すべきは①ベビーゲート（階段・キッチン周り）②コーナーガード（テーブル角）③ファーストシューズ（アシックス・ニューバランスが国内人気）④手押し車（プレウォーカー）⑤後追い対策のベビーサークルです。転倒・誤飲対策の安全用品を揃えることが最重要。ベビーカーはバギータイプに切り替える家庭も多い時期です。' }
    ];
    const CATEGORIES = ['出産準備期','新生児期','離乳食期','安全グッズ期'];

    function getResult(answers) {
      const scores = [0,0,0,0];
      const a = answers.map(x => x.idx);
      if(a[0]===0) scores[0]+=5;
      if(a[0]===1) scores[1]+=5;
      if(a[0]===2) scores[2]+=5;
      if(a[0]===3) scores[3]+=5;
      if(a[4]===0) { scores[0]+=1; }
      if(a[4]===3) { scores[0]+=1; scores[1]+=1; }
      if(a[3]===1) { scores[0]+=1; }
      if(a[3]===2) { scores[1]+=1; scores[2]+=1; }
      const best = scores.indexOf(Math.max(...scores));
      return { result: RESULTS[best], scores, best };
    }

    function loadHistory() {
      const h = localStorage.getItem('baby-product-history');
      return h ? JSON.parse(h) : [];
    }

    function saveToHistory(answers, resultIdx) {
      const h = loadHistory();
      h.unshift({ date: new Date().toISOString(), answers, resultIdx, scores: getResult(answers).scores });
      if(h.length > 50) h.pop();
      localStorage.setItem('baby-product-history', JSON.stringify(h));
      updateHistoryBanner();
    }

    function updateHistoryBanner() {
      const h = loadHistory();
      const banner = document.getElementById('history-banner');
      if(h.length > 0) banner.style.display = 'block';
      else banner.style.display = 'none';
    }

    function showPreviousResult() {
      const h = loadHistory();
      if(h.length === 0) return;
      const prev = h[0];
      const r = getResult(prev.answers);
      displayResult(r, prev.date);
    }

    function toggleHistoryList() {
      const list = document.getElementById('history-list');
      if(list.style.display === 'none') {
        list.style.display = 'block';
        renderHistoryList();
      } else {
        list.style.display = 'none';
      }
    }

    function renderHistoryList() {
      const h = loadHistory();
      const container = document.getElementById('history-items');
      container.innerHTML = h.map((item, i) => {
        const d = new Date(item.date);
        const dateStr = d.toLocaleDateString('ja-JP', {month:'numeric', day:'numeric', hour:'2-digit', minute:'2-digit'});
        const r = RESULTS[item.resultIdx];
        return `<button onclick="showHistoryItem(${i})" style="width:100%;padding:12px;border:1px solid #d1d5db;border-radius:8px;text-align:left;background:#fff;cursor:pointer;transition:.2s;">
          <p style="margin:0 0 4px;font-size:13px;font-weight:600;color:#374151;">${dateStr}</p>
          <p style="margin:0;font-size:12px;color:#6b7280;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${r.title}</p>
        </button>`;
      }).join('');
    }

    function showHistoryItem(idx) {
      const h = loadHistory();
      const item = h[idx];
      const r = getResult(item.answers);
      displayResult(r, item.date);
    }

    function renderChart(scores) {
      const ctx = document.getElementById('result-chart').getContext('2d');
      if(window.chartInstance) window.chartInstance.destroy();
      window.chartInstance = new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: CATEGORIES,
          datasets: [{
            data: scores,
            backgroundColor: ['#3B82F6', '#0284c7', '#06b6d4', '#14b8a6'],
            borderColor: ['#1e40af', '#0369a1', '#0891b2', '#0d9488'],
            borderWidth: 2
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { position: 'bottom' } }
        }
      });
    }

    function displayResult(result, date) {
      document.getElementById('quiz-area').style.display = 'none';
      document.getElementById('quiz-start').style.display = 'none';
      document.getElementById('r-title').textContent = result.result.title;
      document.getElementById('r-desc').textContent = result.result.desc;
      document.getElementById('score-value').textContent = Math.round(Math.max(...result.scores));
      document.getElementById('score-display').style.display = 'block';
      document.getElementById('result-chart-container').style.display = 'block';
      document.getElementById('result').classList.add('show');
      setTimeout(() => renderChart(result.scores), 100);
    }

    function exportResult() {
      const h = loadHistory();
      let csv = 'date,category,score\n';
      h.forEach(item => {
        const d = new Date(item.date).toLocaleDateString('ja-JP');
        const cat = CATEGORIES[item.resultIdx];
        const score = Math.max(...item.scores);
        csv += `"${d}","${cat}",${score}\n`;
      });
      const blob = new Blob([csv], {type: 'text/csv'});
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'baby-product-results.csv';
      a.click();
      URL.revokeObjectURL(url);
    }

    // ★初期化★
    const BTN='#3B82F6'; let cur=0; const ans=[];
    document.addEventListener('DOMContentLoaded',()=>{
      document.getElementById('q-total').textContent=QUESTIONS.length;
      updateHistoryBanner();
    });

    function startQuiz(){
      cur=0; ans.length=0;
      document.getElementById('quiz-start').style.display='none';
      document.getElementById('history-banner').style.display='none';
      document.getElementById('history-list').style.display='none';
      document.getElementById('quiz-area').style.display='block';
      document.getElementById('result').classList.remove('show');
      renderQ();
    }

    function renderQ(){
      const q=QUESTIONS[cur];
      document.getElementById('q-num').textContent=cur+1;
      document.getElementById('q-bar').style.width=((cur+1)/QUESTIONS.length*100)+'%';
      document.getElementById('q-text').textContent=q.text;
      document.getElementById('q-options').innerHTML=q.opts.map((o,i)=>`<button onclick="answer(${i})" style="width:100%;padding:12px;margin-bottom:8px;border:2px solid #e5e7eb;border-radius:10px;font-size:14px;cursor:pointer;background:#fff;text-align:left;">${o}</button>`).join('');
    }

    function answer(idx){
      ans.push({idx});
      cur++;
      if(cur>=QUESTIONS.length) showResult();
      else renderQ();
    }

    function showResult(){
      const r = getResult(ans);
      saveToHistory(ans, r.best);
      displayResult(r);
    }

    // 目標管理機能（M6）
    function loadGoals() {
      const g = localStorage.getItem('baby-product-goals');
      return g ? JSON.parse(g) : [];
    }

    function saveGoals() {
      const selected = [];
      for(let i = 0; i < 4; i++) {
        if(document.getElementById('goal-' + i).checked) selected.push(i);
      }
      localStorage.setItem('baby-product-goals', JSON.stringify(selected));
      closeGoalModal();
      updateGoalDashboard();
    }

    function openGoalModal() {
      const modal = document.getElementById('goal-modal');
      const goals = loadGoals();
      modal.style.display = 'flex';
      for(let i = 0; i < 4; i++) {
        document.getElementById('goal-' + i).checked = goals.includes(i);
      }
    }

    function closeGoalModal() {
      document.getElementById('goal-modal').style.display = 'none';
    }

    function clearGoals() {
      if(confirm('目標をクリアしますか？')) {
        localStorage.removeItem('baby-product-goals');
        updateGoalDashboard();
      }
    }

    function updateGoalDashboard() {
      const goals = loadGoals();
      const dashboard = document.getElementById('goal-dashboard');
      if(goals.length === 0) {
        dashboard.style.display = 'none';
        return;
      }
      dashboard.style.display = 'block';
      const h = loadHistory();
      const maxScores = [0, 0, 0, 0];
      h.forEach(item => {
        item.scores.forEach((s, i) => {
          if(s > maxScores[i]) maxScores[i] = s;
        });
      });
      const container = document.getElementById('goal-progress-items');
      container.innerHTML = goals.map(idx => {
        const categoryName = CATEGORIES[idx];
        const maxScore = maxScores[idx] || 0;
        const targetScore = 5;
        const progress = Math.min(100, Math.round(maxScore / targetScore * 100));
        const completed = progress >= 100;
        return `<div style="padding:10px;background:white;border-radius:8px;border-left:4px solid ${completed ? '#10b981' : '#f59e0b'};">
          <p style="margin:0 0 4px;font-size:13px;font-weight:600;color:#374151;">${completed ? '✅' : '📍'} ${categoryName}</p>
          <div style="height:8px;background:#e5e7eb;border-radius:4px;overflow:hidden;margin-bottom:4px;">
            <div style="height:100%;background:${completed ? '#10b981' : '#f59e0b'};width:${progress}%;"></div>
          </div>
          <p style="margin:0;font-size:11px;color:#6b7280;">${progress}% (${maxScore}/${targetScore})</p>
        </div>`;
      }).join('');
    }

    // 初期化時に目標ダッシュボード表示
    document.addEventListener('DOMContentLoaded', () => {
      document.getElementById('q-total').textContent = QUESTIONS.length;
      updateHistoryBanner();
      updateGoalDashboard();
    });
    </script>
